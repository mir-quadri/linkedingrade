KIT_API_KEY=your_kit_v4_api_key_here
KIT_FORM_ID=your_kit_form_id_here  # numeric, e.g. 9436996

# /audit feature — transactional email (Resend). When unset, the /audit
# flow still works; the report renders on the result page but no email is
# sent. Set these in Vercel before production launch.
RESEND_API_KEY=
EMAIL_FROM=  # e.g. "LinkedInGrade <audit@linkedingrade.com>" — domain must be verified in Resend

# /audit feature — persistent storage (Vercel KV / Upstash Redis). When
# unset, the /audit flow falls back to a per-instance in-memory store
# (records lost on cold start). Provision Vercel KV and set both vars
# before production launch — these are populated automatically by the
# Vercel KV integration.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# /audit feature — pepper for SHA-256-hashed IPs in audit records. Keep
# this secret and stable; rotating it invalidates the hash chain. Generate
# with: openssl rand -hex 32
IP_HASH_PEPPER=

# /api/judge — AI judge proxy (PR B3 unit 1).
# Server-only secret; NEVER expose to the client bundle. When unset, the
# judge returns `judge_unavailable` and the engine falls back to its
# structural-only audit (sections show `needsReview: true` as today).
ANTHROPIC_API_KEY=
# Override the Anthropic model. Default: claude-sonnet-4-5 (the current
# publicly-released Sonnet 4.x alias). Pin a dated id (e.g.
# claude-sonnet-4-5-20250929) for deterministic deploys — Anthropic
# updates the alias as new minor versions ship.
JUDGE_MODEL=
# Hard cap on output tokens per judge call. Default: 1500.
JUDGE_MAX_OUTPUT_TOKENS=
# Per-key daily rate limit. Default: 50. The key is the SHA-256-hashed IP
# (when present) — both server-to-server and browser-origin callers share
# the same daily counter, keyed by IP hash, so a noisy single client can't
# exhaust the budget for everyone.
JUDGE_RATE_LIMIT_PER_DAY=
# Auth — set BOTH:
#   - JUDGE_PROXY_SECRET: shared secret the audit pipeline sends via
#     `X-Judge-Auth`. No browser ever sees this. `openssl rand -hex 32`.
#   - JUDGE_ALLOWED_ORIGINS: comma-separated list of browser origins that
#     can call the proxy directly. Add the site origin and (later) the
#     Chrome extension id, e.g.
#     https://linkedingrade.com,chrome-extension://cnnnbdgkiblailjaacdpkbhmeeaijpao
JUDGE_PROXY_SECRET=
JUDGE_ALLOWED_ORIGINS=
# Cost-per-audit pricing (USD per 1M tokens). Override if Anthropic
# pricing changes — defaults match Sonnet 4.x at PR-B3 launch.
JUDGE_PRICE_INPUT_USD_PER_MILLION=
JUDGE_PRICE_OUTPUT_USD_PER_MILLION=
